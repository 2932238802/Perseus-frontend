{
    "version": "1.0",
    "description": "Los IDE ToolChain Configuration",
    "sharedTools": {
        "cmake": {
            "category": "BuildTool",
            "name": "CMake",
            "executables": [
                "cmake.exe",
                "cmake"
            ],
            "startupArgs": [],
            "requireNodeJs": false,
            "versionArgs": "--version",
            "downloadUrl": "https://cmake.org/download/",
            "validateKey": "cmake version",
            "supportedLanguages": [
                "CXX",
                "CSHARP",
                "CUDA"
            ]
        },
        "ninja": {
            "category": "BuildTool",
            "name": "Ninja Build",
            "executables": [
                "ninja.exe",
                "ninja"
            ],
            "startupArgs": [],
            "requireNodeJs": false,
            "versionArgs": "--version",
            "downloadUrl": "https://ninja-build.org/",
            "validateKey": "ninja",
            "supportedLanguages": [
                "CXX",
                "RUST"
            ]
        },
        "git": {
            "category": "BuildTool",
            "name": "Git",
            "executables": [
                "git.exe",
                "git"
            ],
            "startupArgs": [],
            "requireNodeJs": false,
            "versionArgs": "--version",
            "downloadUrl": "https://git-scm.com/",
            "validateKey": "git version",
            "supportedLanguages": [
                "CXX",
                "RUST",
                "PYTHON",
                "CSHARP"
            ]
        }
    },
    "toolchains": {
        "CXX": {
            "defaults": {
                "compiler": "g++",
                "lsp": "clangd",
                "buildTool": "cmake"
            },
            "tools": {
                "g++": {
                    "category": "Compiler",
                    "name": "C++ (g++ / clang++)",
                    "executables": [
                        "g++.exe",
                        "g++",
                        "clang++.exe",
                        "clang++"
                    ],
                    "startupArgs": [],
                    "requireNodeJs": false,
                    "versionArgs": "--version",
                    "downloadUrl": "https://www.msys2.org/",
                    "validateKey": "g++"
                },
                "clangd": {
                    "category": "LSP",
                    "name": "clangd",
                    "executables": [
                        "clangd.exe",
                        "clangd"
                    ],
                    "startupArgs": [
                        "--background-index",
                        "--clang-tidy"
                    ],
                    "requireNodeJs": false,
                    "versionArgs": "--version",
                    "downloadUrl": "https://github.com/clangd/clangd/releases",
                    "validateKey": "clangd"
                },
                "clang-format": {
                    "category": "Formatter",
                    "name": "clang-format",
                    "executables": [
                        "clang-format.exe",
                        "clang-format"
                    ],
                    "startupArgs": [],
                    "requireNodeJs": false,
                    "versionArgs": "--version",
                    "downloadUrl": "https://clang.llvm.org/",
                    "validateKey": "clang-format"
                }
            }
        },
        "RUST": {
            "defaults": {
                "compiler": "cargo",
                "lsp": "rust-analyzer",
                "buildTool": "cargo"
            },
            "tools": {
                "cargo": {
                    "category": "Compiler",
                    "name": "Rust (cargo)",
                    "executables": [
                        "cargo.exe",
                        "cargo"
                    ],
                    "startupArgs": [],
                    "requireNodeJs": false,
                    "versionArgs": "--version",
                    "downloadUrl": "https://rustup.rs/",
                    "validateKey": "cargo"
                },
                "rust-analyzer": {
                    "category": "LSP",
                    "name": "rust-analyzer",
                    "executables": [
                        "rust-analyzer.exe",
                        "rust-analyzer"
                    ],
                    "startupArgs": [],
                    "requireNodeJs": false,
                    "versionArgs": "--version",
                    "downloadUrl": "https://rust-analyzer.github.io/",
                    "validateKey": "rust-analyzer"
                }
            }
        },
        "PYTHON": {
            "defaults": {
                "compiler": "python",
                "lsp": "pyright",
                "buildTool": ""
            },
            "tools": {
                "python": {
                    "category": "Compiler",
                    "name": "Python 3",
                    "executables": [
                        "python.exe",
                        "python3.exe",
                        "python3",
                        "python"
                    ],
                    "startupArgs": [],
                    "requireNodeJs": false,
                    "versionArgs": "--version",
                    "downloadUrl": "https://www.python.org/downloads/",
                    "validateKey": "Python"
                },
                "pyright": {
                    "category": "LSP",
                    "name": "Pyright",
                    "executables": [
                        "pyright-langserver.cmd",
                        "pyright-langserver"
                    ],
                    "startupArgs": [
                        "--stdio"
                    ],
                    "requireNodeJs": true,
                    "versionArgs": "--version",
                    "downloadUrl": "https://github.com/microsoft/pyright",
                    "validateKey": "pyright"
                },
                "black": {
                    "category": "Formatter",
                    "name": "Black",
                    "executables": [
                        "black.exe",
                        "black"
                    ],
                    "startupArgs": [],
                    "requireNodeJs": false,
                    "versionArgs": "--version",
                    "downloadUrl": "https://github.com/psf/black",
                    "validateKey": "black"
                }
            }
        },
        "CSHARP": {
            "defaults": {
                "compiler": "csc",
                "lsp": "omnisharp",
                "buildTool": "cmake"
            },
            "tools": {
                "csc": {
                    "category": "Compiler",
                    "name": "C# Compiler",
                    "executables": [
                        "csc.exe",
                        "csc"
                    ],
                    "startupArgs": [],
                    "requireNodeJs": false,
                    "versionArgs": "-version",
                    "downloadUrl": "https://dotnet.microsoft.com/",
                    "validateKey": "Microsoft"
                },
                "omnisharp": {
                    "category": "LSP",
                    "name": "OmniSharp",
                    "executables": [
                        "OmniSharp.exe",
                        "omnisharp"
                    ],
                    "startupArgs": [
                        "--languageserver"
                    ],
                    "requireNodeJs": false,
                    "versionArgs": "--version",
                    "downloadUrl": "https://github.com/OmniSharp/omnisharp-roslyn",
                    "validateKey": "OmniSharp"
                }
            }
        },
        "CMAKE": {
            "defaults": {
                "compiler": "",
                "lsp": "neocmakelsp",
                "buildTool": ""
            },
            "tools": {
                "neocmakelsp": {
                    "category": "LSP",
                    "name": "NeoCMakeLSP",
                    "executables": [
                        "neocmakelsp.exe",
                        "neocmakelsp"
                    ],
                    "startupArgs": [
                        "stdio"
                    ],
                    "requireNodeJs": false,
                    "versionArgs": "--version",
                    "downloadUrl": "https://github.com/Decodetalkers/neocmakelsp/releases",
                    "validateKey": "neocmakelsp"
                }
            }
        }
    }
}